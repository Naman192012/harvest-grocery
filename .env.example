# Supabase (used for auth)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Airtable Integration
AIRTABLE_BASE_ID="appXXXXXXXXXXXXXX"
AIRTABLE_API_TOKEN="patXXXXXXXXXXXXXX..."
AIRTABLE_PRODUCTS_TABLE_NAME="Products"
AIRTABLE_VENDORS_TABLE_NAME="Vendors"
AIRTABLE_CATEGORIES_TABLE_NAME="Categories"
AIRTABLE_CACHE_TTL_SECONDS=300
AIRTABLE_TIMEOUT_MS=10000
AIRTABLE_MAX_RETRIES=3
AIRTABLE_FALLBACK_ENABLED=true

# Note: Firebase auth has been removed. Using localStorage-based sessions.
